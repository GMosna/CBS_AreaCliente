# ============================================================
# SASSI IMÓVEIS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no git.
# ============================================================

# --- Supabase Database ---
# Encontre em: Dashboard → Settings → Database → Connection string
# Transaction pooler (porta 6543) — usado pelo Prisma Client em runtime
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (porta 5432) — usado por migrações e scripts
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# --- Supabase API ---
# Encontre em: Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- ERP da empresa (MySQL/MariaDB) ---
# Banco de dados do ERP onde ficam os dados dos inquilinos
ERP_MYSQL_HOST="192.168.0.xxx"
ERP_MYSQL_PORT="3306"
ERP_MYSQL_DATABASE="nome_do_banco_erp"
ERP_MYSQL_USER="usuario_readonly"
ERP_MYSQL_PASSWORD="senha_aqui"

# --- Segurança ---
# Gere uma chave aleatória com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CPF_SECRET_KEY="cole_aqui_sua_chave_de_64_chars_hexadecimais"

# JWT_SECRET para assinar access tokens (15 min)
#   openssl rand -base64 64
JWT_SECRET="cole_aqui_outro_secret_de_64_chars"

# JWT_REFRESH_SECRET para assinar refresh tokens (7 dias) — DIFERENTE do JWT_SECRET
#   openssl rand -base64 64
JWT_REFRESH_SECRET="cole_aqui_outro_secret_diferente_do_jwt_secret"

# --- Google Sheets Sync ---
# ID da planilha Google Sheets (na URL: /spreadsheets/d/<SHEETS_ID>/edit)
SHEETS_ID="cole_aqui_o_id_da_planilha"

# JSON completo da Service Account do Google Cloud (minificado em uma linha)
# Veja README_SHEETS.md para instruções de como gerar
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"sassi-sync@projeto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# Token de autenticação para a rota /api/admin/sync
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SYNC_TOKEN="cole_aqui_token_secreto_para_sync_manual"

# Secret do Vercel Cron (configurado automaticamente no dashboard Vercel)
# Deixe em branco se não estiver usando Vercel
CRON_SECRET=""

# URL da aplicação em produção (usado pelo script cron-sync.ts)
APP_URL="https://seu-dominio.vercel.app"

# URL pública do portal — usada nos links gerados em e-mails (aprovação, notificações)
# Em produção: https://clube.sassiimoveis.com.br
# Em dev: http://localhost:3001 (links nos e-mails apontarão para localhost)
NEXT_PUBLIC_APP_URL="https://clube.sassiimoveis.com.br"

# E-mails dos admins que recebem notificações de novos leads aguardando aprovação
# Separe múltiplos e-mails por vírgula
ADMIN_NOTIFICATION_EMAIL="guilherme.ti.sassi@gmail.com,rjacon@gmail.com"

# Secret HMAC para assinar/verificar tokens de aprovação de parceiros
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVAL_SECRET="cole_aqui_secret_para_aprovacao_de_parceiros"

# --- Gmail SMTP — envio de e-mail ---
# Conta Gmail que enviará os e-mails
GMAIL_USER="imobiliariasassi@gmail.com"
# App Password gerada em: Conta Google → Segurança → Verificação em duas etapas → Senhas de app
# (NÃO é a senha normal do Gmail — é uma senha de 16 chars gerada especificamente para apps)
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# --- URLs dos projetos (usadas nos tokens compartilhados e links cross-site) ---
NEXT_PUBLIC_PORTAL_URL="https://portal.sassimoveis.com.br"
NEXT_PUBLIC_LANDING_URL="https://sassimoveis.com.br"
